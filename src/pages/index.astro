---
import { Image } from "astro:assets"
import { getCollection } from "astro:content"
import ProfilePicture from "~/assets/piotrkulpinski.webp"
import HoverList from "~/components/global/HoverList.astro"
import Intro from "~/components/global/Intro.astro"
import Item from "~/components/global/Item.astro"
import Prose from "~/components/global/Prose.astro"
import PostList from "~/components/PostList.astro"
import ProjectList from "~/components/ProjectList.astro"
import BaseLayout from "~/layouts/BaseLayout.astro"

const allPosts = await getCollection("posts", ({ data }) => !data.isDraft)
const allProjects = await getCollection("projects")

const posts = allPosts.sort(
  (a, b) => new Date(b.data.pubDate).valueOf() - new Date(a.data.pubDate).valueOf(),
)

const projects = allProjects.sort((a, b) => b.data.year - a.data.year)

const contacts = [
  { label: "piotr(at)", value: "kulpinski.pl", href: "mailto:piotr@kulpinski.pl" },
  { label: "x.com/", value: "piotrkulpinski", href: "https://x.com/piotrkulpinski" },
  {
    label: "bsky.app/profile/",
    value: "kulpinski.dev",
    href: "https://bsky.app/profile/kulpinski.dev",
  },
  { label: "github.com/", value: "piotrkulpinski", href: "https://github.com/piotrkulpinski" },
]
---

<BaseLayout>
  <section class="reveal flex items-start gap-5" style="--i: 0">
    <Image
      src={ProfilePicture}
      alt="Piotr Kulpinski"
      width={256}
      height={256}
      class="size-16 rounded-full ring-1 ring-border md:size-20"
    />

    <div class="flex flex-col gap-1.5">
      <h1 class="text-lg font-semibold tracking-tight text-foreground md:text-xl">
        Piotr Kulpinski
      </h1>
      <p class="text-secondary leading-relaxed">
        Solopreneur building directory websites and SaaS from Kraków, PL. Writing about
        software, SEO, and the joy of shipping small things.
      </p>
    </div>
  </section>

  <Intro id="about">
    <h2 slot="title">About</h2>

    <Prose>
      <p>
        I was born in the late 80s in Kraków, Poland, where I still live and work today. For
        15+ years I've been building software — first inside agencies and product teams,
        more recently as an independent solopreneur shipping projects under my own name.
      </p>
      <p>
        I run <a href="https://openalternative.co" target="_blank" rel="noopener noreferrer">OpenAlternative</a>,
        the largest directory of open source software, and <a href="https://dirstarter.com" target="_blank" rel="noopener noreferrer">Dirstarter</a>,
        a Next.js boilerplate that powers a growing number of indie directories. Alongside
        them I'm always tinkering on smaller bets.
      </p>
      <p>
        I care about minimalism, simplicity, and using AI to ship faster than I have any
        right to. I build in public, and most of what I learn ends up here.
      </p>
    </Prose>
  </Intro>

  <Intro id="projects">
    <h2 slot="title">Projects</h2>

    <ProjectList projects={projects} />
  </Intro>

  <Intro id="posts">
    <h2 slot="title">Writing</h2>

    <PostList posts={posts} />
  </Intro>

  <Intro id="contact">
    <h2 slot="title">Elsewhere</h2>

    <HoverList>
      {contacts.map((c, i) => (
        <Item index={i} href={c.href} target="_blank" rel="nofollow noreferrer">
          <span class="font-medium">
            <span class="text-muted">{c.label}</span>{c.value}
          </span>
        </Item>
      ))}
    </HoverList>
  </Intro>
</BaseLayout>
