---
import { getCollection } from "astro:content"
import PostList from "~/components/PostList.astro"
import Prose from "~/components/global/Prose.astro"
import BaseLayout from "~/layouts/BaseLayout.astro"

const allPosts = await getCollection("posts", ({ data }) => !data.isDraft)

const posts = allPosts.sort(
  (a, b) => new Date(b.data.pubDate).valueOf() - new Date(a.data.pubDate).valueOf()
)

const title = "Writing"
---

<BaseLayout title={title}>
  <header class="reveal flex flex-col gap-2" style="--i: 0">
    <h1 class="text-3xl font-semibold tracking-tight text-foreground md:text-4xl">{title}</h1>
    <p class="text-secondary">
      Notes on software, SEO, open source, and the craft of shipping small things.
    </p>
  </header>

  <Prose>
    <PostList posts={posts} />
  </Prose>
</BaseLayout>
